# CPU Usage & RAM Usage Detector
get_cpu_usage() {
    local stat_cache="$CACHE_DIR/cpu_stat.cache"
    local u n s i io ir so st
    read -r _ u n s i io ir so st _ _ < /proc/stat

    local total=$(( u+n+s+i+io+ir+so+st ))
    local idle=$(( i+io ))

    if [[ -f "$stat_cache" ]]; then
        local pu pn ps pi pio pir pso pst
        read -r pu pn ps pi pio pir pso pst < "$stat_cache"
        local ptotal=$(( pu+pn+ps+pi+pio+pir+pso+pst ))
        local pidle=$(( pi+pio ))
        local dt=$(( total-ptotal ))
        local di=$(( idle-pidle ))
        
        (( dt > 0 )) && echo $(( (100*(dt-di) + dt/2) / dt )) || echo 0
    else
        echo 0
    fi

    if [[ "${LIVE_MODE:-false}" == true ]]; then
        printf '%s %s %s %s %s %s %s %s\n' "$u" "$n" "$s" "$i" "$io" "$ir" "$so" "$st" > "$stat_cache"
    fi
}

get_ram_usage() {
    if [ "$(uname)" = "Linux" ]; then
        local key val total=0 avail=0
        while read -r key val _; do
            case $key in
                MemTotal:)     total=$val ;;
                MemAvailable:) avail=$val; break ;;
            esac
        done < /proc/meminfo
        (( total > 0 )) && printf '%d' $(( 100 * (total - avail) / total )) || printf '0'
    else
        vm_stat | awk '/Pages active/ {print int(($2 * 4096 / 1024 / 1024) / ($(sysctl -n hw.memsize)/1024/1024) * 100)}'
    fi
}

RAM=$(get_ram_usage)

# Cyber bar theme
cyber_bar() {
    local percent=$1
    local width=22
    local filled=$((percent * width / 100))
    local bar=""

    for ((i=0; i<filled; i++)); do
        if (( i < filled/2 )); then
            bar+="${FILLED1_COLOR}█"
        else
            bar+="${FILLED2_COLOR}█"
        fi
    done

    for ((i=filled; i<width; i++)); do
        bar+="${EMPTY_COLOR}─"
    done

    [[ "$percent" =~ ^[0-9]+$ ]] || percent=0
    printf "%b\e[0m %3d%%" "$bar" "$percent"
}

