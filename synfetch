# Animated Uptime
get_uptime() {
    local uptime_seconds
    if [[ -f /proc/uptime ]]; then
        uptime_seconds=$(cut -d. -f1 /proc/uptime)
    else
        local boot_time
        boot_time=$(sysctl -n kern.boottime | awk -F'[=, ]+' '{print $5}')
        uptime_seconds=$(( $(date +%s) - boot_time ))
    fi

    local days=$(( uptime_seconds / 86400 ))
    local hours=$(( (uptime_seconds % 86400) / 3600 ))
    local mins=$(( (uptime_seconds % 3600) / 60 ))

    local result=""

    if [ "$days" -gt 0 ]; then
        result+="${days} day$([[ $days -ne 1 ]] && echo "s")"
    fi

    if [ "$hours" -gt 0 ]; then
        [[ -n "$result" ]] && result+=", "
        result+="${hours} hour$([[ $hours -ne 1 ]] && echo "s")"
    fi

    if [ "$mins" -gt 0 ]; then
        [[ -n "$result" ]] && result+=", "
        result+="${mins} minute$([[ $mins -ne 1 ]] && echo "s")"
    fi

    if [[ -z "$result" ]]; then
        result="just started"
    fi

    echo "$result"
}

