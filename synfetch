# Live Uptime

get_uptime() {
    if [ "$(uname)" = "Linux" ]; then
        local up _
        { read -r up _; } < /proc/uptime
        up=${up%.*} 
    else
        local up=$(sysctl -n kern.boottime 2>/dev/null | awk -F' = ' '{print $2}' | tr -d ',')
        up=$(( $(date +%s) - up ))
    fi

    local days=$((up / 86400))
    local hours=$(( (up % 86400) / 3600 ))
    local mins=$(( (up % 3600) / 60 ))

    local result=""

    (( days > 0 )) && result+="${days}d "
    (( hours > 0 || days > 0 )) && result+="${hours}h "
    result+="${mins}m"

    echo "$result"
}

