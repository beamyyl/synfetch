# Real-time Monitoring

synfetch_live() {
    clear
    tput civis

    trap 'tput cnorm; clear; exit 0' INT

    while true; do
        CPU=$(get_cpu_usage 2>/dev/null || echo 0)
        RAM=$(get_ram_usage 2>/dev/null || echo 0)
        GPU_USAGE=$(get_gpu_usage 2>/dev/null || echo 0)

        tput cup 0 0

        if $USE_ASCII; then
            echo -e "$ART"
            echo
        fi

        echo -e " ${OS_COLOR}${ICON_OS}${RESET}OS      ${OS_COLOR}${DISTRO}${RESET}"
        echo -e " ${KERNEL_COLOR}${ICON_KERNEL}${RESET}Kernel  ${KERNEL_COLOR}${KERNEL}${RESET}"
        echo -e " ${USER_COLOR}${ICON_USER}${RESET}User    ${USER_COLOR}${USER}${RESET}"
        echo -e " ${HOST_COLOR}${ICON_HOST}${RESET}Host    ${HOST_COLOR}${HOSTNAME}${RESET}"
        echo -e " ${MOBO_COLOR}${ICON_MOBO}${RESET}MoBo    ${MOBO_COLOR}${MOBO}${RESET}"
        echo -e " ${CPU_COLOR}${ICON_CPU}${RESET}CPU     ${CPU_COLOR}${CPU_MODEL}${RESET}"
        echo -e " ${GPU_COLOR}${ICON_GPU}${RESET}GPU     ${GPU_COLOR}${GPU}${RESET}"
        echo -e " ${UPTIME_COLOR}${ICON_UPTIME}${RESET}Uptime  ${UPTIME_COLOR}$(get_uptime)${RESET}"
        echo -e " ${SHELL_COLOR}${ICON_SHELL}${RESET}Shell   ${SHELL_COLOR}${SHELL_NAME}${RESET}"
        echo -e " ${DEWM_COLOR}${ICON_DEWM}${RESET}DE/WM   ${DEWM_COLOR}${de_wm}${RESET}"
        echo -e " ${PKGS_COLOR}${ICON_PKGS}${RESET}Pkgs    ${PKGS_COLOR}${PKG_COUNT}${RESET}"
        echo -e " ${SEPARATOR_COLOR}────────────────────────────────────────${RESET}"
        echo -e " ${BAR_LABEL_COLOR}CPU${RESET}     $(cyber_bar "${CPU}")"
        echo -e " ${BAR_LABEL_COLOR}RAM${RESET}     $(cyber_bar "${RAM}")"
        if [[ "$GPU_USAGE" != "N/A" && "$GPU_USAGE" != "0" ]]; then
            echo -e " ${BAR_LABEL_COLOR}GPU${RESET}     $(cyber_bar "${GPU_USAGE}")"
        fi
        echo -e " ${SEPARATOR_COLOR}────────────────────────────────────────${RESET}"
        echo -e " ${DIM}Press Ctrl+C to exit live mode${RESET}                "
        sleep 0.4
    done
}

