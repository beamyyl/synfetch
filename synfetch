# GPU & GPU Usage Detector

get_gpu() {
    local gpu_list=()
    
    if command -v lspci >/dev/null 2>&1; then
        while read -r line; do
            [[ -n "$line" ]] && gpu_list+=("$line")
        done < <(lspci -nn 2>/dev/null | grep -E 'VGA|3D|Display' | sed 's/.*: //' | sed '
            s/ (rev .*)$//;
            s/\[[0-9a-fx:]\+\]//g;
            s/Advanced Micro Devices, Inc\. \[AMD\/ATI\]/AMD Radeon/;
            s/Advanced Micro Devices, Inc\./AMD/;
            s/Intel Corporation/Intel/;
            s/NVIDIA Corporation/NVIDIA/;
            s/NVIDIA [A-Z0-9]\{2,6\} \[/NVIDIA [/;
            s| / Radeon .* Series||i;
            s/3D controller: //i;
            s/VGA compatible controller: //i;
            s/Display controller: //i;
            s/\[//g; s/\]//g;
            s/ Max-Q//i;
            s/ Laptop//i;
            s/ Mobile//i;
            s/ *\/ *$//;
            s/^ *//; s/ *$//;
        ' | sort -u)
    fi

    if [ ${#gpu_list[@]} -eq 0 ] && command -v nvidia-smi >/dev/null 2>&1; then
        local nvidia_name
        nvidia_name=$(nvidia-smi --query-gpu=name --format=csv,noheader,nounits 2>/dev/null | head -n1)
        [[ -n "$nvidia_name" && "$nvidia_name" != "NVIDIA" ]] && gpu_list+=("NVIDIA $nvidia_name")
    fi

    if [ ${#gpu_list[@]} -gt 0 ]; then
        (IFS=' + '; echo "${gpu_list[*]}")
    else
        if [ -d /sys/class/drm/card0/device ]; then
            local vendor
            vendor=$(cat /sys/class/drm/card0/device/vendor 2>/dev/null)
            case "$vendor" in
                0x10de) echo "NVIDIA GPU" ;;
                0x1002) echo "AMD GPU" ;;
                0x8086) echo "Intel GPU" ;;
                *)      echo "Integrated Graphics" ;;
            esac
        else
            echo "Unknown GPU"
        fi
    fi
}

get_gpu_usage() {
    if [ "$(uname)" != "Linux" ]; then
        echo "N/A"
        return
    fi

    if command -v nvidia-smi >/dev/null 2>&1; then
        local usage
        usage=$(nvidia-smi --query-gpu=utilization.gpu --format=csv,noheader,nounits 2>/dev/null | head -n1 | tr -d ' %')
        if [[ "$usage" =~ ^[0-9]+$ ]]; then
            echo "$usage"
            return
        fi
    fi

    local amdgpu_usage=0
    for card in /sys/class/drm/card*/device/gpu_busy_percent; do
        if [ -f "$card" ]; then
            local val
            val=$(cat "$card" 2>/dev/null || echo 0)
            if [[ "$val" =~ ^[0-9]+$ ]] && (( val > amdgpu_usage )); then
                amdgpu_usage=$val
            fi
        fi
    done
    if (( amdgpu_usage > 0 )); then
        echo "$amdgpu_usage"
        return
    fi

       if command -v intel_gpu_top >/dev/null 2>&1; then
        local usage
        usage=$(timeout 0.2s intel_gpu_top -s 500 -o - 2>/dev/null \
                | awk 'NR==3 {print $2; exit}' | tr -d ' %' || echo "0")
        if [[ "$usage" =~ ^[0-9]+$ ]] && (( usage > 0 )); then
            echo "$usage"
            return
        fi
    fi

    echo "0"
}

# CPU Model Detector

get_cpu_model() {
    if [ "$(uname)" = "Darwin" ]; then
        sysctl -n machdep.cpu.brand_string 2>/dev/null || echo "Unknown CPU"
        return
    fi

    if [ -r /proc/cpuinfo ]; then
        local model
        model=$(awk -F': ' '/^model name/ {print $2; exit}' /proc/cpuinfo 2>/dev/null)
        if [ -n "$model" ]; then
            echo "$model" | sed 's/ with Radeon.*//; s/^ *//; s/ *$//'
            return
        fi

        model=$(awk -F': ' '/^Processor/ {print $2; exit}' /proc/cpuinfo 2>/dev/null)
        if [ -n "$model" ]; then
            echo "$model" | sed 's/^ *//; s/ *$//'
            return
        fi

        model=$(awk -F': ' '/^Hardware/ {print $2; exit}' /proc/cpuinfo 2>/dev/null)
        if [ -n "$model" ]; then
            echo "$model" | sed 's/^ *//; s/ *$//'
            return
        fi
    fi

    if command -v lscpu >/dev/null 2>&1; then
        lscpu | grep "^Model name:" | sed 's/.*: *//; s/ with Radeon.*//; s/^ *//; s/ *$//'
        return
    fi

    echo "Unknown CPU"
}

# Package Detector

pkg_count() {
    local pkgs=()
    local count

    if command -v dpkg >/dev/null; then
        count=$(dpkg-query -f '${binary:Package}\n' -W 2>/dev/null | wc -l)
        pkgs+=("$count (dpkg)")
    elif command -v rpm >/dev/null; then
        count=$(rpm -qa 2>/dev/null | wc -l)
        pkgs+=("$count (rpm)")
    elif command -v apk >/dev/null; then
        count=$(apk info -q 2>/dev/null | wc -l)
        pkgs+=("$count (apk)")
    elif command -v xbps-query >/dev/null; then
        count=$(xbps-query -l 2>/dev/null | wc -l)
        pkgs+=("$count (xbps)")
    elif command -v qlist >/dev/null; then
        count=$(qlist -I 2>/dev/null | wc -l)
        pkgs+=("$count (emerge)")
    elif command -v guix >/dev/null; then
        count=$(guix package -I 2>/dev/null | wc -l)
        pkgs+=("$count (guix)")
    elif command -v nix-store >/dev/null; then
        count=$(nix-store -q --requisites /run/current-system 2>/dev/null | wc -l || echo 0)
        pkgs+=("$count (nix)")
    elif command -v slackpkg >/dev/null || [ -d /var/log/packages ]; then
        count=$(ls /var/log/packages/ 2>/dev/null | wc -l)
        pkgs+=("$count (slackware)")
    elif command -v brew >/dev/null; then
        local formulas=$(brew list --formula 2>/dev/null | wc -l)
        local casks=$(brew list --cask 2>/dev/null | wc -l)
        pkgs+=("$formulas (formulas) + $casks (casks) = $((formulas + casks)) (brew)")
    elif command -v port >/dev/null; then
        count=$(port -q installed 2>/dev/null | wc -l)
        pkgs+=("$count (MacPorts)")
    elif command -v pkgutil >/dev/null || command -v pkg >/dev/null; then
        count=$(pkgutil --pkgs 2>/dev/null | wc -l)
        pkgs+=("$count (Fink/pkgutil)")
    elif command -v pacman >/dev/null; then
        count=$(pacman -Qq 2>/dev/null | wc -l)
        pkgs+=("$count (pacman)")
    elif ls /Programs >/dev/null 2>&1; then
        count=$(ls /Programs 2>/dev/null | wc -l)
        pkgs+=("$count (programs)")
    fi

    if command -v flatpak >/dev/null; then
        local fp_count=$(flatpak list 2>/dev/null | wc -l)
        if [ "$fp_count" -gt 0 ]; then
            pkgs+=("$fp_count (flatpak)")
        fi
    fi

    if [ ${#pkgs[@]} -eq 0 ]; then
        echo "?"
    else
        echo "${pkgs[*]}"
    fi
}

# Cache for speed

CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/synfetch"
[[ -d "$CACHE_DIR" ]] || mkdir -p "$CACHE_DIR" 2>/dev/null || true
REFRESH=${REFRESH:-false}

_CACHE_RESULT=""

cache() {
    local key="$1"
    local cmd="$2"
    local ttl="${3:-3600}"
    local cache_file="$CACHE_DIR/${key}.cache"
    local exp_file="$CACHE_DIR/${key}.exp"
    local exp now

    printf -v now '%(%s)T' -1

    exp=0
    [[ -f "$exp_file" ]] && read -r exp < "$exp_file"

    if [[ "$REFRESH" == true ]] || [[ ! -f "$cache_file" ]] || (( now >= exp )); then
        eval "$cmd" > "$cache_file" 2>/dev/null || printf 'Unknown\n' > "$cache_file"
        printf '%d\n' $(( now + ttl )) > "$exp_file"
    fi
    _CACHE_RESULT=$(< "$cache_file")
}

