# Argument Parsing
parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
           --config)
                echo -e "${BLUE}Config Location:${RESET} ${CONFIG_FILE}"
                if [ -n "$EDITOR" ]; then
                    $EDITOR "$CONFIG_FILE"
                elif command -v nano >/dev/null 2>&1; then
                    nano "$CONFIG_FILE"
                elif command -v micro >/dev/null 2>&1; then
                    micro "$CONFIG_FILE"
                elif command -v nvim >/dev/null 2>&1; then
                    nvim "$CONFIG_FILE"
                elif command -v vim >/dev/null 2>&1; then
                    vim "$CONFIG_FILE"
                elif command -v vi >/dev/null 2>&1; then
                    vi "$CONFIG_FILE"
                elif command -v emacs >/dev/null 2>&1; then
                    emacs -nw "$CONFIG_FILE"
                elif command -v gedit >/dev/null 2>&1; then
                    gedit "$CONFIG_FILE" >/dev/null 2>&1 &
                elif command -v mousepad >/dev/null 2>&1; then
                    mousepad "$CONFIG_FILE" >/dev/null 2>&1 &
                elif command -v leafpad >/dev/null 2>&1; then
                    leafpad "$CONFIG_FILE" >/dev/null 2>&1 &
                elif command -v kate >/dev/null 2>&1; then
                    kate "$CONFIG_FILE" >/dev/null 2>&1 &
                elif command -v xed >/dev/null 2>&1; then
                    xed "$CONFIG_FILE" >/dev/null 2>&1 &
		fi                
		exit 0
		;;
	--live)
                LIVE_MODE=true
                ;;
            --theme)
                shift
                THEME="${1,,}"
                ;;
            --random)
                distros=("arch" "cachyos" "ubuntu" "debian" "devuan" "fedora" "linuxmint" "zorinos" "popos" "manjaro" "opensuse" "slackware" "centos" "mxlinux" "guix" "qubesos" "antix" "garuda" "nobara" "bazzite" "kali" "elementaryos" "kdeneon" "deepin" "alpine" "gobo" "lfs" "gentoo" "endeavouros" "artix" "void" "bedrock" "bodhi" "nixos" "macos")
                CUSTOM_DISTRO=${distros[$RANDOM % ${#distros[@]}]}

                rand_hex() { 
			printf "#%06x" "$(( ((RANDOM << 15) | RANDOM) % 0x1000000 ))"
		}

                C1_HEX=$(rand_hex); OS_HEX=$(rand_hex); KERNEL_HEX=$(rand_hex)
                USER_HEX=$(rand_hex); HOST_HEX=$(rand_hex); MOBO_HEX=$(rand_hex)
                CPU_HEX=$(rand_hex); GPU_HEX=$(rand_hex); UPTIME_HEX=$(rand_hex)
                SHELL_HEX=$(rand_hex); DEWM_HEX=$(rand_hex); PKGS_HEX=$(rand_hex)
                BAR_LABEL_HEX=$(rand_hex); BAR_FILLED1_HEX=$(rand_hex)
                BAR_FILLED2_HEX=$(rand_hex); BAR_EMPTY_HEX=$(rand_hex)
                SEPARATOR_HEX=$(rand_hex)
	
                THEME="custom" 
                shift 
	;;
            --cycle-theme)
                themes=("synthwave" "monochrome" "minimal" "dracula" "nord" "catppuccin" "tokyonight" "gruvbox" "custom")
                THEME=${themes[$RANDOM % ${#themes[@]}]}
                shift 
		;;
            --nonerd)
                USE_NERD_FONTS=false
                ;;
            --noascii)
                USE_ASCII=false
                ;;
            --distro)
                shift
                CUSTOM_DISTRO="${1,,}"
                ;;
            --help|-h)
                show_help
                ;;
            --refresh)
                REFRESH=true
                ;;
            *)
                echo -e "${PINK}Error:${RESET} Unknown option '$1'"
                echo -e "Run ${PINK}synfetch --help${RESET} for usage"
                exit 1
                ;;
        esac
        shift
    done
}

