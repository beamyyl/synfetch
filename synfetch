# Real-time Monitoring

synfetch_live() {
    clear
    tput civis

    trap 'tput cnorm; clear; exit 0' INT

    while true; do
        CPU=$(get_cpu_usage 2>/dev/null || echo 0)
        RAM=$(get_ram_usage 2>/dev/null || echo 0)
        GPU_USAGE=$(get_gpu_usage 2>/dev/null || echo 0)

        tput cup 0 0

        if $USE_ASCII; then
            echo -e "$ART"
            echo
        fi
        echo -e " ${NEON_BLUE}${ICON_OS}${RESET}OS      ${NEON_BLUE}${DISTRO}${RESET}"
        echo -e " ${MAGENTA}${ICON_KERNEL}${RESET}Kernel  ${MAGENTA}$(uname -r)${RESET}"
        echo -e " ${BLUE}${ICON_USER}${RESET}User    ${BLUE}${USER}${RESET}"
        echo -e " ${RED}${ICON_HOST}${RESET}Host    ${RED}$(cat /etc/hostname 2>/dev/null || hostname)${RESET}"
        echo -e " ${GREEN}${ICON_MOBO}${RESET}MoBo    ${GREEN}$(cat /sys/class/dmi/id/board_vendor 2>/dev/null || echo "") $(cat /sys/class/dmi/id/board_name 2>/dev/null || echo "")"${RESET}
        echo -e " ${TEAL}${ICON_CPU}${RESET}CPU     ${TEAL}$(lscpu | grep 'Model name' | awk -F: '{gsub(/^[ \t]+|[ \t]+$/, "", $2); print $2}')${RESET}"
#      echo -e " ${PINK}${ICON_GPU}${RESET}GPU     ${PINK}${GPU}${RESET}"
        echo -e " ${PINK}${ICON_UPTIME}${RESET}Uptime  ${PINK}$(uptime | sed -E 's/^[^,]*up *//; s/, *[0-9]+ users?.*//')${RESET}"
        echo -e " ${PURPLE}${ICON_SHELL}${RESET}Shell   ${PURPLE}${SHELL##*/}${RESET}"
        echo -e " ${GRAY}${ICON_DEWM}${RESET}DE/WM   ${GRAY}${de_wm}${RESET}"
        echo -e " ${YELLOW}${ICON_PKGS}${RESET}Pkgs    ${YELLOW}$(pkg_count)${RESET}"
        echo -e " ${GRAY}────────────────────────────────────────${RESET}"
        echo -e " ${PINK}CPU${RESET}     $(cyber_bar "${CPU}")"
        echo -e " ${PINK}RAM${RESET}     $(cyber_bar "${RAM}")"
        if [[ "$GPU_USAGE" != "N/A" && "$GPU_USAGE" != "0" ]]; then
        echo -e " ${PINK}GPU${RESET}     $(cyber_bar "${GPU_USAGE}")"
        fi
        echo -e " ${GRAY}────────────────────────────────────────${RESET}"
        echo -e " ${DIM}Press Ctrl+C to exit live mode${RESET}                "
        sleep 0.7
    done
} 

