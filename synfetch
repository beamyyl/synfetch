# CPU & RAM Usage

get_cpu_usage() {
    if [ "$(uname)" = "Linux" ]; then
        read -r cpu user nice system idle iowait irq softirq steal guest guest_nice < /proc/stat
        total1=$((user + nice + system + idle + iowait + irq + softirq + steal + guest + guest_nice))
        idle1=$((idle + iowait))

        sleep 0.2

        read -r cpu user nice system idle iowait irq softirq steal guest guest_nice < /proc/stat
        total2=$((user + nice + system + idle + iowait + irq + softirq + steal + guest + guest_nice))
        idle2=$((idle + iowait))

        diff_total=$((total2 - total1))
        diff_idle=$((idle2 - idle1))
        usage=$((100 * (diff_total - diff_idle) / diff_total))
        echo "$usage"
    else
        top -l 1 | awk '/^CPU usage/ {print int($3)}'
    fi
}

get_ram_usage() {
    if [ "$(uname)" = "Linux" ]; then
        free -m | awk '/Mem:/ {printf "%d", 100*$3/$2}'
    else
        vm_stat | awk '/Pages active/ {print int(($2 * 4096 / 1024 / 1024) / ($(sysctl -n hw.memsize)/1024/1024) * 100)}'
    fi
}

cyber_bar() {
    local percent=$1
    local width=22
    local filled=$((percent * width / 100))
    local bar=""

    local pulse=$(( (percent % 10) + 80 ))

    for ((i=0; i<filled; i++)); do
        if (( i < filled/2 )); then
            bar+="\e[38;5;201m█"
        else
            bar+="\e[38;5;45m█"
        fi
    done

    for ((i=filled; i<width; i++)); do
        bar+="\e[38;5;236m─"
    done

    printf "%b\e[0m %3d%%" "$bar" "$percent"
}

