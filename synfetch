# Argument Parsing

parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --live)
                LIVE_MODE=true
                ;;
            --theme)
                shift
                THEME="${1,,}"
                ;;
            --nonerd)
                USE_NERD_FONTS=false
                ;;
            --noascii)
                USE_ASCII=false
                ;;
            --distro)
                shift
                CUSTOM_DISTRO="${1,,}"
                ;;
            --help|-h)
                show_help
                ;;
            --refresh)
                REFRESH=true
                ;;
            *)
                echo -e "${PINK}Error:${RESET} Unknown option '$1'"
                echo -e "Run ${PINK}synfetch --help${RESET} for usage"
                exit 1
                ;;
        esac
        shift
    done
}

parse_args "$@"

