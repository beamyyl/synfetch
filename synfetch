    cage) de_wm="Cage (kiosk)" ;;
    waybox) de_wm="Waybox" ;;
    oxwm) de_wm="oxwm" ;;
    exwm) de_wm="exwm" ;; 
    aqua | quartz | macos | darwin) de_wm="macOS (Aqua)" ;;
esac
if [[ "$(uname -s)" == "Darwin" ]]; then
    de_wm="macOS (Aqua)"
fi

if [[ "${de_wm}" == "GNOME" || \
      "${de_wm}" == "KDE Plasma" || \
      "${de_wm}" == "Enlightenment" || \
      "${de_wm}" == "MATE" || \
      "${de_wm}" == "XFCE" || \
      "${de_wm}" == "LXQt" || \
      "${de_wm}" == "Cinnamon" ]]; then
    session_suffix=""
    if [ -n "${XDG_SESSION_TYPE}" ]; then
        case "${XDG_SESSION_TYPE}" in
            wayland) session_suffix=" (Wayland)" ;;
            x11)     session_suffix=" (X11)" ;;
        esac
    elif [ -n "${WAYLAND_DISPLAY}" ]; then
        session_suffix=" (Wayland)"
    elif [ -n "${DISPLAY}" ]; then
        session_suffix=" (X11)"
    fi
    de_wm="${de_wm}${session_suffix}"
fi

# Package Detector

pkg_count() {
    local pkgs=()
    local count

    if command -v dpkg >/dev/null; then
        count=$(dpkg --get-selections | grep -v deinstall | wc -l)
        pkgs+=("$count (dpkg)")

    elif command -v guix >/dev/null; then
        count=$(guix package -I | wc -l)
        pkgs+=("$count (guix)")

    elif command -v rpm >/dev/null; then
        count=$(rpm -qa | wc -l)
        pkgs+=("$count (rpm)")

    elif command -v qlist >/dev/null; then
        count=$(qlist -I | wc -l)
        pkgs+=("$count (portage)")

    elif command -v xbps-query >/dev/null; then
        count=$(xbps-query -l | wc -l)
        pkgs+=("$count (xbps)")

    elif command -v apk >/dev/null; then
        count=$(apk info | wc -l)
        pkgs+=("$count (apk)")

    elif command -v nix-store >/dev/null; then
        count=$(nix-store -q --requisites /run/current-system 2>/dev/null | wc -l || echo 0)
        pkgs+=("$count (nix)")

    elif command -v slackpkg >/dev/null || [ -d /var/log/packages ]; then
        count=$(ls /var/log/packages/ 2>/dev/null | wc -l)
        pkgs+=("$count (slackware)")

    elif command -v brew >/dev/null; then
        local formulas=$(brew list --formula 2>/dev/null | wc -l)
        local casks=$(brew list --cask 2>/dev/null | wc -l)
        pkgs+=("$formulas (formulas) + $casks (casks) = $((formulas + casks)) (brew)")

    elif command -v port >/dev/null; then
        count=$(port -q installed 2>/dev/null | wc -l)
        pkgs+=("$count (MacPorts)")

    elif command -v pkgutil >/dev/null || command -v pkg >/dev/null; then
        count=$(pkgutil --pkgs 2>/dev/null | wc -l)
        pkgs+=("$count (Fink/pkgutil)")

    elif command -v pacman >/dev/null; then
        count=$(pacman -Q | wc -l)
        pkgs+=("$count (pacman)")

    elif command -v flatpak >/dev/null; then
        count=$(flatpak list | wc -l)
        pkgs+=("$count (flatpak)")
        echo "${pkgs[*]}"
        return
    elif ls /Programs >/dev/null 2>&1; then
        count=$(ls /Programs | wc -l)
        pkgs+=("$count (programs)")
    fi

    if command -v flatpak >/dev/null; then
        local fp_count=$(flatpak list | wc -l)
        if [ "$fp_count" -gt 0 ]; then
            pkgs+=("$fp_count (flatpak)")
        fi
    fi

    if [ ${#pkgs[@]} -eq 0 ]; then
        echo "?"
    else
        echo "${pkgs[*]}"
    fi
}

