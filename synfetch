PARENT_SHELL=$(readlink /proc/$PPID/exe 2>/dev/null || ps -p $PPID -o comm= 2>/dev/null || echo "$SHELL")
SHELL_NAME="${PARENT_SHELL##*/}"
SHELL_NAME="${SHELL_NAME#-}" 

# Real-time Monitoring + Top
MAX_PROCS=20
SORT_MODE="cpu"
declare -a PROC_PIDS PROC_USERS PROC_CPUS PROC_MEMS PROC_COMMS
declare -a PAUSED_PIDS 
SELECTED=0
SEARCH_QUERY=""

get_fallback_mobo() {
    printf "%s %s" "$(< /sys/class/dmi/id/board_vendor 2>/dev/null || echo "")" \
                   "$(< /sys/class/dmi/id/board_name 2>/dev/null || echo "")" 2>/dev/null || echo "Unknown MoBo"
}

get_fallback_cpu() {
    get_cpu_model  
}

get_fallback_gpu() {
    get_gpu      
}

get_top_processes() {
    PROC_PIDS=() PROC_USERS=() PROC_CPUS=() PROC_MEMS=() PROC_COMMS=()
    local sort_opt="-%cpu"
    [[ "$SORT_MODE" == "ram" ]] && sort_opt="-%mem"

    local total_mem_mb
    total_mem_mb=$(awk '/MemTotal/ {print int($2/1024)}' /proc/meminfo 2>/dev/null || echo 8192)

    local _ps_out
    _ps_out=$(LC_NUMERIC=C ps -eo pid,user,%cpu,%mem,comm --no-headers --sort="$sort_opt")

    if [[ -n "$SEARCH_QUERY" ]]; then
        _ps_out=$(grep -i -- "$SEARCH_QUERY" <<< "$_ps_out")
    fi

    while read -r pid user cpu mem_percent short_cmd; do
        [[ -z "$pid" ]] && continue
        local mem_mb
        mem_mb=$(awk "BEGIN {printf \"%.0f\", $mem_percent * $total_mem_mb / 100}")
        PROC_PIDS+=("$pid")
        PROC_USERS+=("$user")
        PROC_CPUS+=("$cpu")
        PROC_MEMS+=("$mem_mb")
        PROC_COMMS+=("$short_cmd")
    done < <(head -n "$MAX_PROCS" <<< "$_ps_out")
}

kill_selected() {
    local pid="${PROC_PIDS[$SELECTED]:-}"
    if [[ -z "$pid" || "$pid" == "PID" ]]; then return; fi
    local cmd="${PROC_COMMS[$SELECTED]:0:40}"
    local msg_row=$(( $(tput lines) - 3 ))
    local msg_col=5

    tput cup "$msg_row" "$msg_col"
    tput el
    tput sc
    printf "${C1}Kill PID %s [%s]?${RESET} (t = SIGTERM) (9 = SIGKILL) (any = cancel)" "$pid" "$cmd"
    local kkey=""
    read -t 5 -n 1 -s kkey 2>/dev/null || true
    tput rc
    tput el

    case "$kkey" in
        t|T) kill -15 "$pid" 2>/dev/null; tput cup "$msg_row" "$msg_col"; printf "${GREEN}SIGTERM sent!${RESET}"; sleep 0.8 ;;
        9)   kill -9  "$pid" 2>/dev/null; tput cup "$msg_row" "$msg_col"; printf "${RED}SIGKILL sent!${RESET}"; sleep 0.8 ;;
        *)   return ;;
    esac
    tput cup "$msg_row" "$msg_col"
    tput el
}

pause_selected() {
    local pid="${PROC_PIDS[$SELECTED]:-}"
    if [[ -z "$pid" || "$pid" == "PID" ]]; then return; fi
    local cmd="${PROC_COMMS[$SELECTED]:0:40}"
    local msg_row=$(( $(tput lines) - 3 ))
    local msg_col=5

    tput cup "$msg_row" "$msg_col"
    tput el
    tput sc

    local is_paused=false
    for p in "${PAUSED_PIDS[@]}"; do
        [[ "$p" == "$pid" ]] && is_paused=true && break
    done

    if $is_paused; then
        printf "${C1}Resume PID %s [%s]? (y = yes)${RESET}" "$pid" "$cmd"
    else
        printf "${C1}Pause PID %s [%s]? (y = yes)${RESET}" "$pid" "$cmd"
    fi

    local kkey=""
    read -t 5 -n 1 -s kkey 2>/dev/null || true
    tput rc
    tput el

    if [[ "$kkey" == "y" || "$kkey" == "Y" ]]; then
        if $is_paused; then
            kill -CONT "$pid" 2>/dev/null
            local -a new=()
            for p in "${PAUSED_PIDS[@]}"; do
                [[ "$p" != "$pid" ]] && new+=("$p")
            done
            PAUSED_PIDS=("${new[@]}")
        else
            kill -STOP "$pid" 2>/dev/null
            PAUSED_PIDS+=("$pid")
        fi
    fi

    tput cup "$msg_row" "$msg_col"
    tput el
}

synfetch_live() {
    clear
    printf '\e[?25l'
    stty -icanon -echo
    trap 'printf "\e[?25h\e[2J\e[H"; stty sane; clear; exit 0' INT EXIT

    PAUSED_PIDS=()           
    local LAST_COLS=0
    local LAST_LINES=0
    local WAS_TOO_SMALL=false
    local SHOW_RIGHT_PANEL=true
    local LAST_SHOW_RIGHT_PANEL=true
    local cpu_update_counter=0
    local CPU_UPDATE_EVERY=3

    while true; do
        local size
        size=$(stty size 2>/dev/null || echo "24 80")
        local lines=${size%% *}
        local cols=${size##* }

        [[ -z "$cols" || "$cols" -lt 20 ]] && cols=80
        [[ -z "$lines" || "$lines" -lt 5 ]] && lines=24

        if (( cols < 120 || lines < 24 )); then
            printf '\e[2J\e[H'
            local warn_row=$(( lines / 2 - 4 ))
            local warn_col=$(( (cols - 68) / 2 ))
            (( warn_col < 0 )) && warn_col=0
            printf '\e[%d;%dH' $((warn_row+1)) $((warn_col+1))
            echo -e "${C1}-- TERMINAL TOO SMALL --${RESET}"
            printf '\e[%d;%dH' $((warn_row+2)) $((warn_col+1))
            echo -e "   Need at least → ${YELLOW}120 × 24${RESET}"
            printf '\e[%d;%dH' $((warn_row+3)) $((warn_col+1))
            echo -e "   You have      → ${GRAY}${cols} × ${lines}${RESET}"
            printf '\e[%d;%dH' $((warn_row+4)) $((warn_col+1))
            echo -e "${GRAY}Ctrl+C to exit synfetch --live${RESET}"
            WAS_TOO_SMALL=true
            sleep 0.5
            continue
        fi

        if [ "$cols" != "$LAST_COLS" ] || [ "$lines" != "$LAST_LINES" ] || [ "$WAS_TOO_SMALL" = true ] || [[ "$SHOW_RIGHT_PANEL" != "$LAST_SHOW_RIGHT_PANEL" ]]; then
            printf '\e[2J\e[H'
            LAST_COLS=$cols
            LAST_LINES=$lines
            WAS_TOO_SMALL=false
            LAST_SHOW_RIGHT_PANEL="$SHOW_RIGHT_PANEL"
        fi

        local RIGHT_PANEL_WIDTH=55
        local MIN_GAP=3
        local RIGHT_COL=$(( cols - RIGHT_PANEL_WIDTH ))
        if (( RIGHT_COL < 62 + MIN_GAP )); then
            RIGHT_COL=$((62 + MIN_GAP))
        fi

        if (( cpu_update_counter % CPU_UPDATE_EVERY == 0 )); then
        CPU=$(get_cpu_usage 2>/dev/null || echo 0)
        fi
        cpu_update_counter=$((cpu_update_counter + 1))
       	RAM=$(get_ram_usage 2>/dev/null || echo 0)
        GPU_USAGE=$(get_gpu_usage 2>/dev/null || echo 0)
        get_top_processes

        (( SELECTED >= ${#PROC_PIDS[@]} )) && SELECTED=$(( ${#PROC_PIDS[@]} - 1 ))
        [ ${#PROC_PIDS[@]} -eq 0 ] && SELECTED=0

        local row=0

        if $USE_ASCII; then
            printf '\e[%d;%dH' $((row+1)) 1
            while IFS= read -r art_line; do
                printf '\e[%d;%dH' $((row+1)) 1
                printf "%b${RESET}" "$art_line"
                row=$((row + 1))
            done <<< "$ART"
            printf '\e[%d;%dH' $((row+1)) 1; printf "\n"; row=$((row + 1))
        fi

        [[ "${SHOW_OS:-true}" == true ]]     && { printf '\e[%d;%dH' $((row+1)) 1; prin "$ICON_OS"     "OS"     "$DISTRO"      "$OS_COLOR"; row=$((row+1)); }
        [[ "${SHOW_KERNEL:-true}" == true ]] && { printf '\e[%d;%dH' $((row+1)) 1; prin "$ICON_KERNEL" "Kernel" "$KERNEL"      "$KERNEL_COLOR"; row=$((row+1)); }
        [[ "${SHOW_USER:-true}" == true ]]   && { printf '\e[%d;%dH' $((row+1)) 1; prin "$ICON_USER"   "User"   "$USER"        "$USER_COLOR"; row=$((row+1)); }
        [[ "${SHOW_HOST:-true}" == true ]]   && { printf '\e[%d;%dH' $((row+1)) 1; prin "$ICON_HOST"   "Host"   "$HOSTNAME"    "$HOST_COLOR"; row=$((row+1)); }

        local mobo_print="${MOBO:-}"
        [[ -z "$mobo_print" || "$mobo_print" == *"Unknown"* ]] && mobo_print=$(get_fallback_mobo)
        [[ "${SHOW_MOBO:-true}" == true ]] && { printf '\e[%d;%dH' $((row+1)) 1; prin "$ICON_MOBO" "MoBo" "$mobo_print" "$MOBO_COLOR"; row=$((row+1)); }

        local cpu_print="${CPU_MODEL:-}"
        [[ -z "$cpu_print" || "$cpu_print" == "Unknown CPU" ]] && cpu_print=$(get_fallback_cpu)
        [[ "${SHOW_CPU:-true}" == true ]] && { printf '\e[%d;%dH' $((row+1)) 1; prin "$ICON_CPU" "CPU" "$cpu_print" "$CPU_COLOR"; row=$((row+1)); }

        local gpu_print="${GPU:-}"
        [[ -z "$gpu_print" || "$gpu_print" == "Unknown GPU" ]] && gpu_print=$(get_fallback_gpu)
        [[ "${SHOW_GPU:-true}" == true ]] && { printf '\e[%d;%dH' $((row+1)) 1; prin "$ICON_GPU" "GPU" "$gpu_print" "$GPU_COLOR"; row=$((row+1)); }

        [[ "${SHOW_UPTIME:-true}" == true ]] && { printf '\e[%d;%dH' $((row+1)) 1; prin "$ICON_UPTIME" "Uptime" "$(get_uptime)" "$UPTIME_COLOR"; row=$((row+1)); }
        [[ "${SHOW_SHELL:-true}" == true ]]  && { printf '\e[%d;%dH' $((row+1)) 1; prin "$ICON_SHELL"  "Shell"  "$SHELL_NAME"  "$SHELL_COLOR"; row=$((row+1)); }
        [[ "${SHOW_DEWM:-true}" == true ]]   && { printf '\e[%d;%dH' $((row+1)) 1; prin "$ICON_DEWM"   "DE/WM"  "$de_wm"       "$DEWM_COLOR"; row=$((row+1)); }
        [[ "${SHOW_PKGS:-true}" == true ]]   && { printf '\e[%d;%dH' $((row+1)) 1; prin "$ICON_PKGS"   "Pkgs"   "$PKG_COUNT"   "$PKGS_COLOR"; row=$((row+1)); }
       
       	if [[ "${SHOW_USAGE_BARS:-true}" == true ]]; then
            printf '\e[%d;%dH' $((row+1)) 1; echo -e " ${SEPARATOR_COLOR}────────────────────────────────────────${RESET}"; row=$((row + 1))
            printf '\e[%d;%dH' $((row+1)) 1; printf " ${BAR_LABEL_COLOR}CPU${RESET}     %b\n" "$(cyber_bar "${CPU}")"; row=$((row + 1))
            printf '\e[%d;%dH' $((row+1)) 1; printf " ${BAR_LABEL_COLOR}RAM${RESET}     %b\n" "$(cyber_bar "${RAM}")"; row=$((row + 1))
            if [[ "$GPU_USAGE" != "N/A" && "$GPU_USAGE" != "0" ]]; then
                printf '\e[%d;%dH' $((row+1)) 1; printf " ${BAR_LABEL_COLOR}GPU${RESET}     %b\n" "$(cyber_bar "${GPU_USAGE}")     "; row=$((row + 1))
            fi
            printf '\e[%d;%dH' $((row+1)) 1; echo -e " ${SEPARATOR_COLOR}────────────────────────────────────────${RESET}"; row=$((row + 1))
        fi

        if [[ "$SHOW_RIGHT_PANEL" == true ]]; then
            local right_row=0
            printf '\e[%d;%dH' $((right_row+1)) $((RIGHT_COL+1))
            printf "${C1} PID   PROGRAM           USER        MEMB    CPU ${RESET}"
            right_row=$((right_row + 1))
            printf '\e[%d;%dH' $((right_row+1)) $((RIGHT_COL+1))
            printf "${SEPARATOR_COLOR}──────────────────────────────────────────────────${RESET}"
            right_row=$((right_row + 1))
            local _proc_start_row=$right_row

            if [ ${#PROC_PIDS[@]} -eq 0 ]; then
                printf '\e[%d;%dH' $((right_row+1)) $((RIGHT_COL+1))
                printf "${GRAY}No processes                                        ${RESET}"
                right_row=$((right_row + 1))

            else
                for i in "${!PROC_PIDS[@]}"; do
                    printf '\e[%d;%dH' $((right_row+1)) $((RIGHT_COL+1))
                    local mem_display="${PROC_MEMS[$i]}M"
                    local proc_color="${OS_COLOR}"
                    local is_paused=false
                    for p in "${PAUSED_PIDS[@]}"; do
                        [[ "$p" == "${PROC_PIDS[$i]}" ]] && is_paused=true && break
                    done
                    if $is_paused; then
                        proc_color="${GREEN}"
                    elif (( ${PROC_CPUS[$i]%%.*} >= 25 )) || (( ${PROC_MEMS[$i]} >= 1024 )); then
                        proc_color="${RED}"
                    fi

                    if [ "$i" -eq "$SELECTED" ]; then
                        LC_NUMERIC=C printf "\e[7m${proc_color} %-5s %-17s %-8s %7s %6.1f%% \e[27m\e[0m" \
                            "${PROC_PIDS[$i]}" "${PROC_COMMS[$i]:0:17}" "${PROC_USERS[$i]}" \
                            "$mem_display" "${PROC_CPUS[$i]}"
                    else
                        LC_NUMERIC=C printf "${proc_color} %-5s %-17s %-8s %7s %6.1f%% ${RESET}" \
                            "${PROC_PIDS[$i]}" "${PROC_COMMS[$i]:0:17}" "${PROC_USERS[$i]}" \
                            "$mem_display" "${PROC_CPUS[$i]}"
                    fi
                    right_row=$((right_row + 1))
                done
            fi

            while (( right_row < _proc_start_row + MAX_PROCS + 2 )); do
                printf '\e[%d;%dH' $((right_row+1)) $((RIGHT_COL+1))
                printf '\e[K'
                right_row=$((right_row + 1))
            done
        fi

        local help_row=$((lines - 1))
        local filter_row=$((lines - 2))

        printf '\e[%d;%dH' $((help_row + 1)) 1
        printf '\e[K'
        local status="[k: kill] [p: pause/resume] [c: sort CPU] [r: sort RAM] [/: search] [h: toggle panel] [q: quit]  "
        printf "${C1}${status}${RESET}"

        printf '\e[%d;%dH' $((filter_row + 1)) 1
        printf '\e[K'
        if [[ -n "$SEARCH_QUERY" ]]; then
            printf "${C1}Filter: ${SEARCH_QUERY}${RESET}"
        fi

        local key=""
        if read -t 0.08 -n 1 -s key 2>/dev/null; then
            case "$key" in
                "q"|"Q") printf '\e[2J\e[H'; break ;;
                "/")
                    local _sq=""
                    printf '\e[%d;%dH' $((help_row + 1)) 1
                    printf '\e[K'
                    printf "${YELLOW}Search (leave blank to exit): ${RESET}"
                    while true; do
                        local _ch
                        read -r -s -n 1 _ch
                        if [[ "$_ch" == "" ]]; then break
                        elif [[ "$_ch" == $'\x7f' || "$_ch" == $'\b' ]]; then
                            [[ -n "$_sq" ]] && _sq="${_sq%?}"
                            printf '\e[%d;%dH' $((help_row + 1)) 1
                            printf '\e[K'
                            printf "${YELLOW}Search (leave blank to exit): ${RESET}${_sq}"
                        elif [[ "$_ch" == $'\e' ]]; then _sq=""; break
                        else _sq+="$_ch"; printf "%s" "$_ch"
                        fi
                    done
                    SEARCH_QUERY="$_sq"
                    printf '\e[%d;%dH' $((help_row + 1)) 1
                    printf '\e[K'
                    SELECTED=0
                    ;;
                "k"|"K") kill_selected ;;
                "p"|"P") pause_selected ;;
                "c"|"C") SORT_MODE="cpu"; SELECTED=0 ;;
                "r"|"R") SORT_MODE="ram"; SELECTED=0 ;;
                "h"|"H")
                    if [[ "$SHOW_RIGHT_PANEL" == true ]]; then
                        SHOW_RIGHT_PANEL=false
                    else
                        SHOW_RIGHT_PANEL=true
                    fi
                    ;;
                $'\e')
                    read -t 0.05 -n 1 -s key2; read -t 0.05 -n 1 -s key3
                    [[ "$key3" == "A" ]] && ((SELECTED--))
                    [[ "$key3" == "B" ]] && ((SELECTED++))
                    ;;
            esac
        fi
    done
}

