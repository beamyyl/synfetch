get_gpu_usage() {
    if [ "$(uname)" != "Linux" ]; then
        echo "N/A"
        return
    fi

    if command -v nvidia-smi >/dev/null 2>&1; then
        nvidia-smi --query-gpu=utilization.gpu --format=csv,noheader,nounits 2>/dev/null | head -n1 | tr -d ' %'
        return
    fi

    if [ -f /sys/class/drm/card0/device/gpu_busy_percent ]; then
        cat /sys/class/drm/card0/device/gpu_busy_percent 2>/dev/null || echo "0"
        return
    fi

    echo "0"
}

